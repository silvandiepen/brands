# Open Brands environment variables
# Copy this file to .env and fill in the values for local development.
# Production secrets are configured through `wrangler secret put`.

# CDN origin for immutable asset delivery
PUBLIC_CDN_ORIGIN=https://cdn.open-brands.org

# API origin
PUBLIC_API_ORIGIN=https://api.open-brands.org

# Website origin
PUBLIC_WEB_ORIGIN=https://open-brands.org

# GitHub repository for canonical data
GITHUB_REPOSITORY=silvandiepen/brands

# --- API Worker secrets (configure with `wrangler secret put`) ---
# GITHUB_APP_ID
# GITHUB_APP_PRIVATE_KEY
# GITHUB_CLIENT_ID
# GITHUB_CLIENT_SECRET
# SESSION_SECRET
# TURNSTILE_SECRET
# INTERNAL_RELEASE_TOKEN

# --- Cloudflare (for wrangler deploy) ---
# CLOUDFLARE_API_TOKEN
# CLOUDFLARE_ACCOUNT_ID
