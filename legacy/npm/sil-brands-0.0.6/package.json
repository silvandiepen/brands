{
  "name": "@sil/brands",
  "private": false,
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:data": "npx tsx build/data.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview"
  },
  "files": [
    "lib",
    "lib/svg/*.svg"
  ],
  "exports": {
    ".": {
      "import": "./lib/brands.js",
      "require": "./lib/brands.umd.cjs"
    }
  },
  "dependencies": {
    "@sil/color": "^0.4.14",
    "@sil/id": "^0.0.7",
    "@sil/storage": "^0.0.7",
    "@types/node": "^20.11.26",
    "@vueuse/core": "^10.9.0",
    "bemm": "^1.0.5",
    "cli-block": "^1.4.3",
    "mitt": "^3.0.1",
    "open-icon": "^0.0.17",
    "vite-plugin-dynamic-import": "^1.5.0",
    "vue": "^3.4.19",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "prettier": "^3.2.5",
    "sass": "^1.71.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.4",
    "vite-plugin-static-copy": "^1.0.1",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^1.8.27"
  }
}
